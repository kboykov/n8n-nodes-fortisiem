{
  "name": "n8n-nodes-fortisiem",
  "version": "0.2.0",
  "description": "n8n community node for FortiSIEM security information and event management",
  "keywords": [
    "n8n-community-node-package",
    "fortisiem",
    "fortinet",
    "siem",
    "security"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kboykov/n8n-nodes-fortisiem",
  "author": {
    "name": "kboykov",
    "email": "office@endormo.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kboykov/n8n-nodes-fortisiem.git"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials",
    "lint:fix": "eslint nodes credentials --fix",
    "format": "prettier nodes credentials --write",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist",
    "icons"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FortiSiemApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FortiSiem/FortiSiem.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@types/node": "^18.16.16",
    "eslint": "^8.44.0",
    "eslint-plugin-n8n-nodes-base": "^1.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "^5.1.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
